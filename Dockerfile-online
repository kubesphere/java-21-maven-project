FROM docker.io/maven:3.9-eclipse-temurin-21-alpine AS builder

WORKDIR /build

COPY pom.xml ./
COPY src ./src

RUN mvn clean package -DskipTests

FROM docker.io/eclipse-temurin:21-jre

WORKDIR /home

COPY --from=builder /build/target/java-21-maven-project-*.jar /home/app.jar

RUN groupadd -g 65532 appgroup && \
    useradd -u 65532 -g appgroup -s /bin/false -m appuser

USER 65532:65532

ENTRYPOINT ["java", "-jar", "/home/app.jar"]
